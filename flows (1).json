    {
        "id": "interaction_logic",
        "type": "function",
        "z": "ebf802684285ae98",
        "d": true,
        "name": "Handle Interaction",
        "func": "const data = msg.payload?.data;\nif (!data) return null;\n\nconst userId =\n    msg.payload?.member?.user?.id ||\n    msg.payload?.user?.id;\n\n// 🔘 BUTTON CLICK → OPEN MODAL\nif (data.custom_id === \"open_modal\") {\n\n    msg.payload = {\n        type: \"modal\",\n        title: \"User Form\",\n        custom_id: \"user_form\",\n        components: [\n            {\n                type: 1,\n                components: [\n                    {\n                        type: 4,\n                        custom_id: \"username\",\n                        label: \"Enter your name\",\n                        style: 1,\n                        required: true\n                    }\n                ]\n            }\n        ]\n    };\n\n    return msg;\n}\n\n// 📝 MODAL SUBMIT → READ INPUT\nif (data.custom_id === \"user_form\") {\n\n    const name =\n        data.components?.[0]?.components?.[0]?.value;\n\n    msg.payload = {\n        type: \"reply\",\n        content: `Hello ${name || \"unknown\"} 👋`\n    };\n\n    return msg;\n}\n\n// ❌ ignore everything else\nreturn null;",
