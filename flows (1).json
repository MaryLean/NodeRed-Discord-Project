        "type": "function",
        "z": "ebf802684285ae98",
        "d": true,
        "name": "Handle Reply",
        "func": "const userInput = msg.payload;\n\nflow.set(\"nameOfChara\", userInput);\n\nlet done = false;\n\nif (userInput != \"create\" && !done) {\n    flow.set(\"waiting_for_name\", false);\n}\nif (!flow.get(\"waiting_for_name\")) {\n    flow.set(\"waiting_for_name\", true)\n    msg.payload = {\n        channel: msg.payload.channelId,\n        content: `Welcome ${userInput}!`\n    };\n    let character = {\n        \"name\": userInput\n    };\n\n    let list = global.get(\"character\" || []);\n\n    list.push({\n        name: userInput,\n        lp: 10,\n        owner: msg.payload.authorId,\n        items: []\n    });\n\n    global.set(\"character\", list);\n    done = true;\n\n    return msg;\n}",
